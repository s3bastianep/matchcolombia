# Google Maps (opcional): agrega API key para tiles de Google.
# Sin key se usa OpenStreetMap — mapa 100% interactivo (arrastrar, zoom, pines).

VITE_GOOGLE_MAPS_API_KEY=
# URL canónica del sitio (SEO, Open Graph, sitemap, JSON-LD)
# Ejemplo producción: https://matchcolombia.co o https://www.lumorahome.co
VITE_SITE_URL=https://matchcolombia.co
